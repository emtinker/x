{
  "openapi": "3.0.0",
  "info": {
    "title": "The Pak API",
    "description": "Armada memory system \u2014 read/write PakRecords, send agent messages, get Memory Burrito, fetch calendar data, and log agent messages to the memory pipeline",
    "version": "1.3.0"
  },
  "servers": [
    {
      "url": "https://pak.emtinker.com/functions"
    },
    {
      "url": "https://app.base44.com/api/apps/69dadb27cd4c1b175f393974/functions",
      "description": "Dib Agent API (agentWebhook endpoints)"
    }
  ],
  "paths": {
    "/getPakRecords": {
      "get": {
        "operationId": "getPakRecordsGet",
        "summary": "Query PakRecords (GET)",
        "parameters": [
          {
            "name": "type",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by record type (e.g. milestone, task, memory_burrito)"
          },
          {
            "name": "tags",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of tags to filter by"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Max records to return"
          }
        ],
        "responses": {
          "200": {
            "description": "Array of PakRecords"
          }
        }
      },
      "post": {
        "operationId": "getPakRecords",
        "summary": "Query PakRecords (POST)",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string",
                    "description": "Filter by record type (e.g. milestone, task, memory_burrito)"
                  },
                  "tags": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Filter by tags"
                  },
                  "limit": {
                    "type": "integer",
                    "description": "Max records to return"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Array of PakRecords"
          }
        }
      }
    },
    "/createPakRecord": {
      "post": {
        "operationId": "createPakRecord",
        "summary": "Create a new PakRecord",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "type",
                  "title",
                  "body"
                ],
                "properties": {
                  "type": {
                    "type": "string"
                  },
                  "title": {
                    "type": "string"
                  },
                  "body": {
                    "type": "string"
                  },
                  "tags": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "app_name": {
                    "type": "string"
                  },
                  "recorded_at": {
                    "type": "string",
                    "format": "date-time"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created PakRecord with id"
          }
        }
      }
    },
    "/sendMessage": {
      "post": {
        "operationId": "sendMessage",
        "summary": "Send a message between agents",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "to_agent",
                  "subject",
                  "body"
                ],
                "properties": {
                  "to_agent": {
                    "type": "string"
                  },
                  "subject": {
                    "type": "string"
                  },
                  "body": {
                    "type": "object"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message sent"
          }
        }
      }
    },
    "/getBurrito": {
      "get": {
        "operationId": "getBurritoGet",
        "summary": "Get the latest Memory Burrito (GET)",
        "responses": {
          "200": {
            "description": "Latest Memory Burrito content"
          }
        }
      },
      "post": {
        "operationId": "getBurrito",
        "summary": "Get the latest Memory Burrito (POST)",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Latest Memory Burrito content"
          }
        }
      }
    },
    "/agentHeartbeat": {
      "post": {
        "operationId": "agentHeartbeat",
        "summary": "Agent heartbeat ping",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "agent_name": {
                    "type": "string"
                  },
                  "last_action": {
                    "type": "string"
                  },
                  "status": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Heartbeat acknowledged"
          }
        }
      }
    },
    "/getPakCalendar": {
      "get": {
        "operationId": "getPakCalendarGet",
        "summary": "Get PakRecords as calendar events (GET)",
        "description": "Returns PakRecords shaped as calendar blocks for Mission Control week view.",
        "parameters": [
          {
            "name": "start_date",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Start of date range (YYYY-MM-DD)"
          },
          {
            "name": "end_date",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "End of date range (YYYY-MM-DD)"
          },
          {
            "name": "types",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of record types to filter by"
          }
        ],
        "responses": {
          "200": {
            "description": "Array of calendar events shaped for Mission Control week view"
          }
        }
      },
      "post": {
        "operationId": "getPakCalendar",
        "summary": "Get PakRecords as calendar events (POST)",
        "description": "Returns PakRecords shaped as calendar blocks for Mission Control week view. Filters by date range, returns title, body summary, start/end times, category from tags, and pak_record_id for deep linking.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "start_date": {
                    "type": "string",
                    "format": "date"
                  },
                  "end_date": {
                    "type": "string",
                    "format": "date"
                  },
                  "types": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Array of calendar events shaped for Mission Control week view"
          }
        }
      }
    },
    "/agentWebhook/logMessage": {
      "post": {
        "operationId": "logMessage",
        "summary": "Log an agent message to the memory pipeline",
        "description": "Logs any inbound or outbound agent message to AgentMessage entity. Call on EVERY message exchange \u2014 no filtering. Automatically associates with today's AgentMemory stub via memory_record_id.",
        "servers": [
          {
            "url": "https://app.base44.com/api/apps/69dadb27cd4c1b175f393974/functions"
          }
        ],
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "action",
                  "agent",
                  "direction",
                  "role",
                  "content"
                ],
                "properties": {
                  "action": {
                    "type": "string",
                    "enum": [
                      "logMessage"
                    ]
                  },
                  "agent": {
                    "type": "string",
                    "enum": [
                      "GIR",
                      "DIB",
                      "HERMES"
                    ],
                    "description": "Which agent is logging"
                  },
                  "direction": {
                    "type": "string",
                    "enum": [
                      "inbound",
                      "outbound"
                    ]
                  },
                  "role": {
                    "type": "string",
                    "enum": [
                      "user",
                      "assistant",
                      "system"
                    ]
                  },
                  "content": {
                    "type": "string",
                    "description": "Full message content"
                  },
                  "session_id": {
                    "type": "string"
                  },
                  "memory_record_id": {
                    "type": "string",
                    "description": "Today's AgentMemory stub ID for association"
                  },
                  "message_timestamp": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "channel": {
                    "type": "string",
                    "enum": [
                      "base44",
                      "imessage",
                      "slack",
                      "automation"
                    ]
                  },
                  "flagged": {
                    "type": "boolean",
                    "default": false
                  },
                  "flag_reason": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message logged",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "record_id": {
                      "type": "string"
                    },
                    "agent": {
                      "type": "string"
                    },
                    "direction": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/agentWebhook/createMemoryStub": {
      "post": {
        "operationId": "createMemoryStub",
        "summary": "Create or retrieve today's AgentMemory stub",
        "description": "Idempotent \u2014 creates a new AgentMemory stub record for the given agent and date, or returns the existing one if already created. Called at midnight by each agent's stub automation.",
        "servers": [
          {
            "url": "https://app.base44.com/api/apps/69dadb27cd4c1b175f393974/functions"
          }
        ],
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "action",
                  "agent",
                  "date"
                ],
                "properties": {
                  "action": {
                    "type": "string",
                    "enum": [
                      "createMemoryStub"
                    ]
                  },
                  "agent": {
                    "type": "string",
                    "enum": [
                      "GIR",
                      "DIB",
                      "HERMES"
                    ]
                  },
                  "date": {
                    "type": "string",
                    "format": "date",
                    "description": "Today's date YYYY-MM-DD"
                  },
                  "cycle": {
                    "type": "string",
                    "enum": [
                      "day_start",
                      "morning",
                      "evening"
                    ],
                    "default": "day_start"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Stub record ID",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "record_id": {
                      "type": "string"
                    },
                    "created": {
                      "type": "boolean",
                      "description": "true if new, false if existing returned"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "api_key"
      }
    }
  }
}