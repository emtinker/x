{
  "openapi": "3.0.0",
  "info": {
    "title": "The Pak API",
    "description": "Armada memory system — read/write PakRecords, send agent messages, get Memory Burrito, and fetch calendar-formatted session data",
    "version": "1.2.0"
  },
  "servers": [
    {
      "url": "https://pak.emtinker.com/functions"
    }
  ],
  "paths": {
    "/getPakRecords": {
      "get": {
        "operationId": "getPakRecordsGet",
        "summary": "Query PakRecords (GET)",
        "parameters": [
          { "name": "type", "in": "query", "schema": { "type": "string" }, "description": "Filter by record type (e.g. milestone, task, memory_burrito)" },
          { "name": "tags", "in": "query", "schema": { "type": "string" }, "description": "Comma-separated list of tags to filter by" },
          { "name": "limit", "in": "query", "schema": { "type": "integer" }, "description": "Max records to return" }
        ],
        "responses": {
          "200": { "description": "Array of PakRecords" }
        }
      },
      "post": {
        "operationId": "getPakRecords",
        "summary": "Query PakRecords (POST)",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "type": { "type": "string", "description": "Filter by record type (e.g. milestone, task, memory_burrito)" },
                  "tags": { "type": "array", "items": { "type": "string" }, "description": "Filter by tags" },
                  "limit": { "type": "integer", "description": "Max records to return" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Array of PakRecords" }
        }
      }
    },
    "/createPakRecord": {
      "post": {
        "operationId": "createPakRecord",
        "summary": "Create a new PakRecord",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["type", "title", "body"],
                "properties": {
                  "type": { "type": "string" },
                  "title": { "type": "string" },
                  "body": { "type": "string" },
                  "tags": { "type": "array", "items": { "type": "string" } },
                  "app_name": { "type": "string" },
                  "recorded_at": { "type": "string", "format": "date-time" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Created PakRecord with id" }
        }
      }
    },
    "/sendMessage": {
      "post": {
        "operationId": "sendMessage",
        "summary": "Send a message between agents",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["to_agent", "subject", "body"],
                "properties": {
                  "to_agent": { "type": "string" },
                  "subject": { "type": "string" },
                  "body": { "type": "object" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Message sent" }
        }
      }
    },
    "/getBurrito": {
      "get": {
        "operationId": "getBurritoGet",
        "summary": "Get the latest Memory Burrito (GET)",
        "responses": {
          "200": { "description": "Latest Memory Burrito content" }
        }
      },
      "post": {
        "operationId": "getBurrito",
        "summary": "Get the latest Memory Burrito (POST)",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "type": "object" }
            }
          }
        },
        "responses": {
          "200": { "description": "Latest Memory Burrito content" }
        }
      }
    },
    "/agentHeartbeat": {
      "post": {
        "operationId": "agentHeartbeat",
        "summary": "Agent heartbeat ping",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "agent_name": { "type": "string" },
                  "last_action": { "type": "string" },
                  "status": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Heartbeat acknowledged" }
        }
      }
    },
    "/getPakCalendar": {
      "get": {
        "operationId": "getPakCalendarGet",
        "summary": "Get PakRecords as calendar events (GET)",
        "description": "Returns PakRecords shaped as calendar blocks for Mission Control week view.",
        "parameters": [
          { "name": "start_date", "in": "query", "schema": { "type": "string", "format": "date" }, "description": "Start of date range (YYYY-MM-DD)" },
          { "name": "end_date", "in": "query", "schema": { "type": "string", "format": "date" }, "description": "End of date range (YYYY-MM-DD)" },
          { "name": "types", "in": "query", "schema": { "type": "string" }, "description": "Comma-separated list of record types to filter by" }
        ],
        "responses": {
          "200": { "description": "Array of calendar events shaped for Mission Control week view" }
        }
      },
      "post": {
        "operationId": "getPakCalendar",
        "summary": "Get PakRecords as calendar events (POST)",
        "description": "Returns PakRecords shaped as calendar blocks for Mission Control week view. Filters by date range, returns title, body summary, start/end times, category from tags, and pak_record_id for deep linking.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "start_date": { "type": "string", "format": "date" },
                  "end_date": { "type": "string", "format": "date" },
                  "types": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Array of calendar events shaped for Mission Control week view" }
        }
      }
    }
  }
}
